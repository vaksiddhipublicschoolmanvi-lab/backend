PORT=3000
NODE_ENV=development
DATABASE_URL=postgresql://username:password@host/dbname?sslmode=require

API_KEY=change-this-secret-key

SESSION_DIR=./auth_info

WORKER_ENABLED=true
POLL_INTERVAL_MS=5000
SEND_DELAY_MIN_MS=45000
SEND_DELAY_MAX_MS=120000
MAX_MESSAGES_PER_CYCLE=1
MAX_ATTEMPTS=3
DAILY_MESSAGE_LIMIT=25
PER_PHONE_DAILY_LIMIT=1
MIN_GAP_BETWEEN_MESSAGES_MS=60000
SENDING_START_HOUR=9
SENDING_END_HOUR=18
TIMEZONE=Asia/Kolkata
RESCHEDULE_HOUR=9

APP_NAME=SmartBooks AI WhatsApp Worker
